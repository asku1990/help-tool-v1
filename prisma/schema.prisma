// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  ADMIN
  REGULAR
  GUEST
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userType     UserType @default(REGULAR)

  // Relations
  vehicles     Vehicle[]
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
  INSURANCE
  TAX
  PARKING
  TOLL
  OIL_CHANGE
  OIL_TOP_UP
  INSPECTION
  TIRES
  OTHER
}

model Vehicle {
  id        String   @id @default(uuid())
  userId    String
  name      String
  make      String?
  model     String?
  year      Int?
  licensePlate             String?  @db.VarChar(16)
  inspectionDueDate        DateTime?
  inspectionIntervalMonths Int?
  initialOdometer          Int?      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fillUps   FuelFillUp[]
  expenses  Expense[]
  tireSets  TireSet[]
  tireChanges TireChangeLog[]

  @@index([userId])
  @@index([userId, licensePlate])
}

model FuelFillUp {
  id             String   @id @default(uuid())
  vehicleId      String
  date           DateTime @default(now())
  odometerKm     Int
  liters         Decimal   @db.Decimal(10, 2)
  pricePerLiter  Decimal   @db.Decimal(10, 3)
  totalCost      Decimal   @db.Decimal(10, 2)
  isFull         Boolean   @default(true)
  notes          String?

  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, date])
}

model Expense {
  id              String   @id @default(uuid())
  vehicleId       String
  date            DateTime @default(now())
  category        ExpenseCategory
  amount          Decimal  @db.Decimal(10, 2)
  vendor          String?
  odometerKm      Int?
  liters          Decimal? @db.Decimal(10, 2)
  oilConsumption  Decimal? @db.Decimal(10, 2) // L/10,000km at time of top-up
  notes           String?

  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, date])
}

enum TireType {
  SUMMER
  WINTER
  ALL_SEASON
}

enum TireStatus {
  ACTIVE
  STORED
  RETIRED
}

model TireSet {
  id           String     @id @default(uuid())
  vehicleId    String
  name         String
  type         TireType
  status       TireStatus @default(ACTIVE)
  purchaseDate DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  vehicle      Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  changeLogs   TireChangeLog[]

  @@index([vehicleId])
}

model TireChangeLog {
  id         String   @id @default(uuid())
  vehicleId  String
  tireSetId  String
  date       DateTime @default(now())
  odometerKm Int
  notes      String?
  createdAt  DateTime @default(now())

  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tireSet    TireSet  @relation(fields: [tireSetId], references: [id], onDelete: Cascade)

  @@index([vehicleId, date])
  @@index([tireSetId])
}
